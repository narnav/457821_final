PORT=4000
# Use 127.0.0.1 (not localhost) on macOS + Docker: localhost may resolve to ::1 and hit Postgres.app instead of the container.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/codequest
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too

# LocalStack (development)
AWS_ENDPOINT=http://localhost:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_BUCKET=questcode-avatars

# Production:
# - remove AWS_ENDPOINT
# - set real AWS credentials and S3 bucket
