// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ExerciseType {
  CONCEPT_CARD
  MULTIPLE_CHOICE
  FIND_THE_BUG
  DRAG_DROP
  CODE_FILL
  TAP_TOKEN
}

enum PathType {
  BEGINNER
  ADVANCED
}

enum DuelCategory {
  OUTPUT
  SCOPE
  ASYNC
  TYPES
  METHODS
}

enum RankTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
}

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  username      String
  hashedPassword String
  avatarId      String      @default("avatar-braces")
  avatarUrl     String?
  tokenVersion  Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  lastActiveAt  DateTime?

  progress       UserProgress?
  exerciseHistory UserExerciseHistory[]
  duelRating     DuelRating?
  streakLogs     StreakLog[]
  userBadges     UserBadge[]
  duelSessionsP1 DuelSession[] @relation("Player1Sessions")
  duelSessionsP2 DuelSession[] @relation("Player2Sessions")
  wonSessions    DuelSession[] @relation("WinnerSessions")
  dailyPracticeLogs DailyPracticeLog[]
}

model LearningPath {
  id          String      @id @default(cuid())
  key         PathType    @unique
  title       String
  description String
  chapters    Chapter[]
  progresses  UserProgress[]
}

model Chapter {
  id          String   @id @default(cuid())
  pathId      String
  title       String
  description String
  orderIndex  Int
  lessons     Lesson[]
  path        LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
}

model Lesson {
  id               String      @id @default(cuid())
  chapterId        String
  title            String
  description      String
  estimatedMinutes Int
  orderIndex       Int
  difficulty       Difficulty
  chapter          Chapter      @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  exercises        Exercise[]
}

model Exercise {
  id           String       @id @default(cuid())
  lessonId      String
  type         ExerciseType
  prompt       String
  codeSnippet  String
  correctAnswer String
  explanation  String
  orderIndex   Int
  xpReward     Int
  lesson       Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  options      ExerciseOption[]
  history      UserExerciseHistory[]
}

model ExerciseOption {
  id         String   @id @default(cuid())
  exerciseId String
  text       String
  isCorrect  Boolean  @default(false)
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
}

model UserProgress {
  id               String   @id @default(cuid())
  userId           String   @unique
  pathId           String
  goal             String?
  experienceLevel  String?
  dailyCommitmentMinutes Int?
  notificationsEnabled Boolean @default(true)
  onboardingCompleted Boolean @default(false)
  currentChapterId String?
  currentLessonId  String?
  xpTotal          Int      @default(0)
  level            Int      @default(1)
  streakCurrent    Int      @default(0)
  streakLongest    Int      @default(0)
  streakLastDate   DateTime?
  streakShieldAvailable Boolean @default(false)
  streakShieldConsumedAt DateTime?
  heartsRemaining  Int      @default(3)
  heartsLastRefill DateTime?
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  path             LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
}

model DailyPracticeLog {
  id                       String   @id @default(cuid())
  userId                   String
  dateKey                  String
  practicedSeconds         Int      @default(0)
  incompleteReminderCount  Int      @default(0)
  completeReminderSent     Boolean  @default(false)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dateKey])
}

model UserExerciseHistory {
  id          String   @id @default(cuid())
  userId      String
  exerciseId  String
  isCorrect   Boolean
  attempts    Int
  timeTakenMs Int
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise    Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
}

model DuelQuestion {
  id           String       @id @default(cuid())
  questionText String
  codeSnippet  String
  correctAnswer String
  type         ExerciseType
  difficulty   Difficulty
  category     DuelCategory
  options      Json?
  explanation  String       @default("")
  timesUsed    Int          @default(0)
  correctRate  Float        @default(1)
}

model DuelSession {
  id               String   @id @default(cuid())
  player1Id        String
  player2Id        String
  winnerId         String?
  player1Score     Int      @default(0)
  player2Score     Int      @default(0)
  roundsPlayed     Int      @default(0)
  roundReplay      Json?
  startedAt        DateTime @default(now())
  endedAt          DateTime?
  disconnectReason String?
  player1          User     @relation("Player1Sessions", fields: [player1Id], references: [id], onDelete: Cascade)
  player2          User     @relation("Player2Sessions", fields: [player2Id], references: [id], onDelete: Cascade)
  winner           User?    @relation("WinnerSessions", fields: [winnerId], references: [id], onDelete: SetNull)
}

model DuelRating {
  id       String   @id @default(cuid())
  userId   String   @unique
  rating   Int      @default(1000)
  wins     Int      @default(0)
  losses   Int      @default(0)
  draws    Int      @default(0)
  rankTier RankTier @default(BRONZE)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Badge {
  id                  String   @id @default(cuid())
  name                String   @unique
  description         String
  iconKey             String
  category            String
  unlockConditionJson String
  users               UserBadge[]
}

model UserBadge {
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@id([userId, badgeId])
}

model StreakLog {
  id                String   @id @default(cuid())
  userId            String
  date              DateTime
  xpEarned          Int      @default(0)
  exercisesCompleted Int     @default(0)
  lessonsCompleted  Int      @default(0)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}
